RTMP_HOST=0.0.0.0
RTMP_PORT=1935
API_HOST=0.0.0.0
API_PORT=8081
MEDIA_DIR=./data
HLS_SEGMENT_DURATION=4
HLS_SEGMENTS_KEEP=10
RECORDING_ENABLED=true
THUMBNAIL_SIZES=320,480
THUMBNAIL_INTERVAL_SECONDS=300
# Thumbnails are generated in JPEG XL, AVIF, and PNG formats
# When THUMBNAIL_LIVE_UPDATE=false, each live stream gets a single thumbnail
# (generated once when none exists) instead of continuously refreshing.
THUMBNAIL_LIVE_UPDATE=true
THUMBNAIL_FFMPEG_CONCURRENCY=4
THUMBNAIL_RATE_LIMIT_SECONDS=5
RECORDINGS_BASE_URL=/recordings
STREAM_GRACE_PERIOD_SECONDS=30
RECORDING_REMUX_ENABLED=true
RECORDING_REMUX_CONCURRENCY=4
